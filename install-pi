#!/usr/bin/env bash
set -euo pipefail

DOTFILES="$HOME/projects/dotagent"
PI="$HOME/.pi/agent"

mkdir -p "$PI/skills"

ln -sf "$DOTFILES/CLAUDE.md" "$PI/AGENTS.md"

for skill in "$DOTFILES/skills/"/*/; do
  ln -sf "$skill" "$PI/skills/$(basename "$skill")"
done

PI_PACKAGES=(
  "npm:@ff-labs/pi-fff"
  "npm:context-mode"
  "npm:pi-subagents"
  "npm:pi-mcp-adapter"
  "npm:pi-lens"
  "npm:@juicesharp/rpiv-ask-user-question"
  "npm:@juicesharp/rpiv-btw"
  "npm:@juicesharp/rpiv-pi"
  "npm:@samfp/pi-memory"
  "npm:pi-vim"
  "npm:@casualjim/pi-superpowers"
)

SETTINGS="$PI/settings.json"
echo "Installing Pi packages..."
for pkg in "${PI_PACKAGES[@]}"; do
  if [[ -f "$SETTINGS" ]] && grep -qF "\"$pkg\"" "$SETTINGS"; then
    echo "  already installed: $pkg"
  else
    echo "  installing: $pkg"
    pi install "$pkg"
  fi
done

echo "Pi configured."
