{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 365,
  "permissions": {
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Read(**/.env*)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"session_end\": true}' >> ~/.claude/session.log"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$(date): wrote $CLAUDE_FILE_PATHS\" >> .claude/writes.log"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Context compacting — writing session state...' && cat .claude/writes.log >> SESSION_SUMMARY.md"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline"
  },
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": false,
  "theme": "dark-ansi",
  "editorMode": "vim",
  "effortLevel": "medium"
}
